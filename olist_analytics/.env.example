# Environment variables for Olist dbt project
# Copy to .env and fill in your values

# GCP Project Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_DATASET_RAW=raw
GCP_DATASET_DEV=olist_dev
GCP_DATASET_PROD=olist_prod
GCP_REGION=US

# dbt Configuration
DBT_PROFILES_DIR=./
DBT_TARGET=dev  # or prod
DBT_THREADS=4   # dev: 4, prod: 8

# BigQuery Configuration
BQ_KEYFILE_PATH=~/.dbt/gcp-sa-key.json

# Kestra Configuration (for orchestration)
KESTRA_API_URL=http://localhost:8080
KESTRA_NAMESPACE=dev

# Data Ranges
START_DATE=2016-01-01
END_DATE=2018-12-31
